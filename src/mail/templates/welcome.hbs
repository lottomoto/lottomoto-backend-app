<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body style="margin: 0; padding: 0; background-color: #F1F5F9; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;">
  <table width="100%" cellpadding="0" cellspacing="0" style="background-color: #F1F5F9; padding: 40px 0;">
    <tr>
      <td align="center">
        <table width="500" cellpadding="0" cellspacing="0" style="background-color: #FFFFFF; border-radius: 12px; overflow: hidden;">
          <!-- Header -->
          <tr>
            <td style="background-color: #0D1B3E; padding: 32px; text-align: center;">
              <div style="width: 48px; height: 48px; background-color: #D4AF37; border-radius: 12px; display: inline-block; line-height: 48px; font-size: 20px; font-weight: bold; color: #0D1B3E;">LD</div>
              <p style="color: #FFFFFF; font-size: 18px; font-weight: bold; margin: 12px 0 0;">La Différence</p>
              <p style="color: #D4AF37; font-size: 12px; margin: 4px 0 0; letter-spacing: 2px;">MOTO / LOTTO</p>
            </td>
          </tr>
          <!-- Body -->
          <tr>
            <td style="padding: 32px;">
              <h2 style="color: #0D1B3E; font-size: 22px; margin: 0 0 8px;">Bienvenue, {{firstname}} !</h2>
              <p style="color: #64748B; font-size: 14px; line-height: 1.6; margin: 0 0 24px;">
                Votre compte a été créé sur le système <strong style="color: #0D1B3E;">La Différence Moto/Lotto</strong>.
                Voici vos identifiants de connexion :
              </p>
              <!-- Credentials box -->
              <table width="100%" cellpadding="0" cellspacing="0" style="background-color: #F1F5F9; border-radius: 8px; margin-bottom: 24px;">
                <tr>
                  <td style="padding: 20px;">
                    <table width="100%" cellpadding="0" cellspacing="0">
                      <tr>
                        <td style="padding: 4px 0;">
                          <span style="color: #64748B; font-size: 13px;">Email</span>
                        </td>
                        <td style="padding: 4px 0; text-align: right;">
                          <span style="color: #0D1B3E; font-size: 13px; font-weight: 600;">{{email}}</span>
                        </td>
                      </tr>
                      <tr>
                        <td colspan="2" style="padding: 8px 0;">
                          <div style="border-top: 1px solid #E2E8F0;"></div>
                        </td>
                      </tr>
                      <tr>
                        <td style="padding: 4px 0;">
                          <span style="color: #64748B; font-size: 13px;">Mot de passe</span>
                        </td>
                        <td style="padding: 4px 0; text-align: right;">
                          <code style="background-color: #0D1B3E; color: #D4AF37; padding: 4px 12px; border-radius: 6px; font-size: 14px; font-weight: bold; letter-spacing: 1px;">{{password}}</code>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>
              <!-- Warning -->
              <p style="color: #DC2626; font-size: 12px; margin: 0 0 24px; padding: 12px; background-color: #FEF2F2; border-radius: 6px;">
                ⚠️ Veuillez changer votre mot de passe après votre première connexion.
              </p>
              <!-- CTA -->
              <table width="100%" cellpadding="0" cellspacing="0">
                <tr>
                  <td align="center">
                    <a href="{{loginUrl}}" style="display: inline-block; background-color: #D4AF37; color: #0D1B3E; padding: 14px 32px; border-radius: 8px; text-decoration: none; font-weight: bold; font-size: 14px;">Se connecter</a>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
          <!-- Footer -->
          <tr>
            <td style="padding: 20px 32px; border-top: 1px solid #E2E8F0; text-align: center;">
              <p style="color: #94A3B8; font-size: 11px; margin: 0;">La Différence Moto/Lotto — Accès sécurisé</p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
